  "stratagems": [
    {
      "name": "Strike Once, Strike Well",
      "id": "1cece39c-28a0-51df-a25c-7302745c69ac",
      "cost": 1,
      "turn": "either",
      "target": "One KROOT unit from your army that has not been selected to fight this phase.",
      "when": "Your Fight phase.",
      "effect": "Until the end of the phase, improve the Armour Penetration characteristic of melee weapons equipped by models in your unit by 1, and those weapons have the [LANCE] ability.",
      "restrictions": "",
      "type": "Battle Tactic",
      "phase": ["fight"],
      "fluff": "After the hunt comes a moment when the predators must strike with all their force, aiming to disembowel or open the throat of the prey and leave it unable to escape or fight back.",
      "detachment": "Preybane War Party",
      "faction_id": "basic"
    },
    {
      "name": "Pheremonal Markings",
      "id": "2789fb80-90cd-556b-8825-1c3bdfcf31ec",
      "cost": 1,
      "turn": "your",
      "target": "One KROOT unit from your army within range of an objective marker you control.",
      "when": "Your Command phase.",
      "effect": "That objective marker remains under your control until your opponent’s Level of Control over that objective marker is greater than yours at the end of a phase.",
      "restrictions": "",
      "type": "Epic Deed",
      "phase": ["command"],
      "fluff": "Though invisible to foes, these pheromone trails are clearly discernible to the Kroot. They let them know which regions the prey have been driven from and allow them to focus their hunt elsewhere.",
      "detachment": "Preybane War Party",
      "faction_id": "basic"
    },
    {
      "name": "Lure and Strike",
      "id": "4acaf1b2-8ea8-5038-b73e-ee8c3a821e92",
      "cost": 1,
      "turn": "your",
      "target": "That KROOT unit.",
      "when": "Your Movement phase, just after a KROOT unit from your army Falls Back.",
      "effect": "Until the end of the turn, your unit is eligible to shoot and declare a charge in a turn in which it Fell Back.",
      "restrictions": "",
      "type": "Strategic Ploy",
      "phase": ["movement"],
      "fluff": "Cunning predators, the Kroot feign weakness and panicked flight before turning with avian swiftness to strike their now-overextended prey.",
      "detachment": "Preybane War Party",
      "faction_id": "basic"
    }
