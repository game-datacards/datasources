      "cost": 1,
      "turn": "your",
      "target": "One HERETIC ASTARTES unit from your army that has not been selected to shoot this phase.",
      "when": "Your Shooting phase.",
      "effect": "Until the end of the phase, ranged weapons equipped by models in your unit have the [IGNORES COVER] ability.",
      "restrictions": "",
      "type": "Battle Tactic",
      "phase": ["shooting"],
      "fluff": "Cacodaemonic wisps bedevil the foe, emitting screeches and sprays of leaping sparks that betray the position of even the best-hidden enemies.",
      "detachment": "Warpsmith’s Gauntlet",
      "faction_id": "basic"
    },
    {
      "name": "Muzzleblaze Slaughter",
      "id": "33776e9d-328f-5441-9c5f-6f4387a0ecfb",
      "cost": 1,
      "turn": "your",
      "target": "One HERETIC ASTARTES unit from your army that is within Engagement Range of one or more enemy units and has not been selected to shoot this phase.",
      "when": "Your Shooting phase.",
      "effect": "Until the end of the phase, your unit’s ranged weapons have the [PISTOL] ability.",
      "restrictions": "",
      "type": "Battle Tactic",
      "phase": ["shooting"],
      "fluff": "Transhuman reactions and infernal cogitation combine, enabling your warriors to unleash point-blank annihilation with the heaviest weapons.",
